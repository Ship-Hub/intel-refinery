# Intel Refinery — Environment Configuration
# Copy to .env and fill in values

# === Server ===
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# === Database ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=intel_refinery

# === OpenRouter (Primary AI Provider) ===
OPENROUTER_API_KEY=
OPENROUTER_TIMEOUT_MS=120000

# === Model Routing Config ===
# Each task type can use a different model. Uses OpenRouter model IDs.
OPENROUTER_EXTRACTION_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_RELATIONSHIP_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_STRUCTURE_MODEL=anthropic/claude-opus
OPENROUTER_REPORT_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_QUALITY_MODEL=openai/gpt-5.5
OPENROUTER_CONTRADICTION_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_ENTITY_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_GAP_MODEL=anthropic/claude-sonnet
OPENROUTER_QUESTION_MODEL=deepseek/deepseek-v4-flash

# === Legacy AI Providers (fallback) ===
AI_PROVIDER=gemini
AI_FALLBACK_PROVIDER=
AI_PROVIDER_TIMEOUT_MS=120000
AI_MAX_PROVIDER_ATTEMPTS=2

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama
OLLAMA_MODEL=qwen2.5:14b

# === Auth ===
PLATFORM_ADMIN_TOKEN=
GOOGLE_CLIENT_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
FRONTEND_BASE_URL=

# === V1 API Rate Limiting ===
V1_RATE_LIMIT_WINDOW_MS=60000
V1_RATE_LIMIT_MAX=60
V1_RATE_LIMIT_PER_KEY_WINDOW_MS=60000
V1_RATE_LIMIT_PER_KEY_MAX=60

# === Webhooks ===
WEBHOOK_RETRY_INTERVAL_SECONDS=60
WEBHOOK_MAX_RETRIES=3
WEBHOOK_CONCURRENCY=5

# === Request Logs ===
REQUEST_LOG_RETENTION_DAYS=90

# === Idempotency ===
IDEMPOTENCY_TTL_HOURS=24

# === Payments ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=